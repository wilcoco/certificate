# ─── API 서버 설정 ───
PORT=4000
API_KEY=your-secret-api-key-here

# ─── Oracle 접속 정보 ───
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECT_STRING=your_host:1521/your_service

# ─── Oracle Thick Mode (Railway 등 Linux 배포 시 필요) ───
ORACLE_USE_THICK_MODE=true
ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient

# ─── Oracle 테이블 이름 ───
ORACLE_EMP_TABLE=T_XX_BSC
ORACLE_DEPT_TABLE=T_XX_DPT
ORACLE_PASS_TABLE=T_XX_PWD

# ─── Oracle 컬럼 이름 (기본값이 CAMS ERP 기준이므로 변경 불필요할 수 있음) ───
# ORACLE_EMP_COL_EMPLOYEE_ID=BSCSBN
# ORACLE_EMP_COL_NAME=BSCNAME
# ORACLE_EMP_COL_RESIDENT_NUMBER=BSCJUMNO
# ORACLE_EMP_COL_DEPT_CODE=BSCDPTCOD
# ORACLE_EMP_COL_DIV_CODE=BSCDIVCOD
# ORACLE_EMP_COL_ADDRESS=BSCJUSO
# ORACLE_EMP_COL_JOIN_DATE=BSCGIYMD
# ORACLE_EMP_COL_RETIRE_DATE=BSCRTYMD
# ORACLE_DEPT_COL_NAME=DPTDPTN
# ORACLE_DEPT_COL_CODE=DPTDPTCOD
# ORACLE_DEPT_COL_DIV_CODE=DPTDIVCOD
# ORACLE_PASS_COL_USER_ID=PWDUSRID
# ORACLE_PASS_COL_PASSWORD=ETC6

# ─── 사번 필터 (사원 목록 조회 시 사용) ───
ORACLE_EMP_ID_PREFIXES=103,2
